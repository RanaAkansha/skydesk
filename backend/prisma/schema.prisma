generator client {
  provider = "prisma-client-js"
}

// generator erd {
//   provider = "prisma-erd-generator"
//   output   = "./ERD.svg"
// }

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum TripStatus {
  PLANNED
  ONGOING
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum TravelClass {
  ECONOMY
  PREMIUM_ECONOMY
  BUSINESS
  FIRST
}

//////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////

model User {
  id            String   @id @default(uuid())
  fullName      String
  email         String   @unique
  password      String
  phone         String?
  profileImage  String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  trips         Trip[]
  chatSessions  ChatSession[]

  @@map("users")
}

//////////////////////////////////////////////////////
// TRIP
//////////////////////////////////////////////////////

model Trip {
  id            String      @id @default(uuid())

  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  title         String

  fromCity      String
  fromCode      String

  toCity        String
  toCode        String

  startDate     DateTime
  endDate       DateTime

  status        TripStatus

  totalBudget   Decimal?    @db.Decimal(10,2)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  bookings      Booking[]
  expenses      Expense[]

  @@index([userId])
  @@map("trips")
}

//////////////////////////////////////////////////////
// FLIGHT
//////////////////////////////////////////////////////

model Flight {
  id             String       @id @default(uuid())

  airline        String
  airlineCode    String
  flightNumber   String       @unique

  logo           String?

  fromCity       String
  fromCode       String

  toCity         String
  toCode         String

  departureTime  DateTime
  arrivalTime    DateTime

  duration       String

  terminal       String?
  gate           String?

  travelClass    TravelClass

  basePrice      Decimal      @db.Decimal(10,2)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  bookings       Booking[]

  @@index([flightNumber])
  @@map("flights")
}

//////////////////////////////////////////////////////
// BOOKING
//////////////////////////////////////////////////////

model Booking {
  id              String          @id @default(uuid())

  bookingCode     String          @unique

  tripId          String
  trip            Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)

  flightId        String
  flight          Flight          @relation(fields: [flightId], references: [id])

  passengers      Int

  seatNumber      String?

  bookingStatus   BookingStatus

  bookingDate     DateTime

  totalPrice      Decimal         @db.Decimal(10,2)

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([tripId])
  @@index([flightId])
  @@map("bookings")
}

//////////////////////////////////////////////////////
// EXPENSE CATEGORY
//////////////////////////////////////////////////////

model ExpenseCategory {
  id            String      @id @default(uuid())

  name          String      @unique

  description   String?

  createdAt     DateTime    @default(now())

  expenses      Expense[]

  @@map("expense_categories")
}

//////////////////////////////////////////////////////
// EXPENSE
//////////////////////////////////////////////////////

model Expense {
  id              String             @id @default(uuid())

  tripId          String
  trip            Trip               @relation(fields: [tripId], references: [id], onDelete: Cascade)

  categoryId      String
  category        ExpenseCategory    @relation(fields: [categoryId], references: [id])

  title           String

  description     String?

  amount          Decimal            @db.Decimal(10,2)

  expenseDate     DateTime

  receiptUrl      String?

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([tripId])
  @@index([categoryId])
  @@map("expenses")
}

//////////////////////////////////////////////////////
// CHAT SESSION
//////////////////////////////////////////////////////

model ChatSession {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  status    String        @default("ACTIVE") // ACTIVE, CLOSED
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]

  @@index([userId])
  @@map("chat_sessions")
}

//////////////////////////////////////////////////////
// CHAT MESSAGE
//////////////////////////////////////////////////////

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String      // "user" or "model" (or "bot")
  text      String
  createdAt DateTime    @default(now())

  @@index([sessionId])
  @@map("chat_messages")
}