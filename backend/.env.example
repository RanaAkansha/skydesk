# SkyDesk Backend - Environment Variable Template

# Port for the Express server to listen on
PORT=5000

# PostgreSQL database connection URL (Prisma compatible)
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# JWT secret key for signing user auth tokens (should be long, random, and secure in production)
JWT_SECRET=your_jwt_secret_key_here

# JWT token expiration duration (e.g. 7d, 24h)
JWT_EXPIRES_IN=7d

# Node environment setting: development or production
NODE_ENV=development

# The URL of the React client (used for CORS configuration)
FRONTEND_URL=http://localhost:5173

# Google Gemini AI API key for grounding chatbot features
GEMINI_API_KEY=your_google_gemini_api_key_here
